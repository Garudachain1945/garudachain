# GarudaChain — root environment example
#
# Copy to .env and fill in the values before starting any service.
# NEVER commit a filled .env to the repository.
#
# Each component has its own env vars; this file is the master reference.
# For production deployments see deploy/garudaapi.env.example and
# deploy/README.md for the full systemd + nginx setup.

# ── GarudaAPI server ───────────────────────────────────────────────────────
# Bind address and port (put nginx/caddy in front for production)
GARUDA_BIND=127.0.0.1
PORT=5098

# Set to 1 in any environment that accepts untrusted traffic
GARUDA_STRICT=0

# Admin key for /api/admin/* endpoints (generate: openssl rand -hex 32)
GARUDA_ADMIN_KEY=REPLACE_WITH_openssl_rand_hex_32

# CORS origins (comma-separated); leave unset for open dev
GARUDA_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Trust X-Forwarded-For from reverse proxy (set to 1 only behind nginx)
GARUDA_TRUST_PROXY=0

# ── RPC credentials (must match bitcoin.conf in each node datadir) ─────────
GARUDA_RPC_USER_CBDC=garudacbdc
GARUDA_RPC_PASS_CBDC=REPLACE_WITH_openssl_rand_hex_24
GARUDA_RPC_HOST_CBDC=127.0.0.1
GARUDA_RPC_PORT_CBDC=6301

GARUDA_RPC_USER_PUBLIC=garudapublic
GARUDA_RPC_PASS_PUBLIC=REPLACE_WITH_openssl_rand_hex_24
GARUDA_RPC_HOST_PUBLIC=127.0.0.1
GARUDA_RPC_PORT_PUBLIC=6301

GARUDA_RPC_USER_CREATOR=garudacreator
GARUDA_RPC_PASS_CREATOR=REPLACE_WITH_openssl_rand_hex_24
GARUDA_RPC_HOST_CREATOR=127.0.0.1
GARUDA_RPC_PORT_CREATOR=6301

# ── Envelope encryption (optional — see SECURITY.md) ──────────────────────
# AES-256 master key as 64 hex chars (openssl rand -hex 32)
# Required only if using GARUDA_*_ENC_FILE variants.
GARUDA_MASTER_KEY=

# Encrypted admin key file (created with the garudaapi --encrypt-key tool)
GARUDA_ADMIN_KEY_ENC_FILE=

# HashiCorp Vault integration (overrides GARUDA_MASTER_KEY when set)
GARUDA_VAULT_ADDR=
GARUDA_VAULT_TOKEN=
GARUDA_VAULT_PATH=secret/data/garudachain/master
GARUDA_VAULT_FIELD=master_key
GARUDA_VAULT_CACERT=

# ── CBDC authority key (crown jewel — use HSM in production) ───────────────
# Hex-encoded 32-byte secp256k1 private key.
# In production: inject from AWS KMS / YubiHSM / HashiCorp Vault.
# Local dev only — NEVER use a real key in a .env file on disk.
GARUDA_AUTH_PRIVKEY=REPLACE_OR_INJECT_FROM_HSM

# ── Treasury / fee sink ────────────────────────────────────────────────────
GARUDA_TREASURY_ADDR=grd1qhaclxgx8xhzxjmwg8meuwp7k2ut53t0equ002s

# Per-transaction cap (GRD) — sanity guard against operator error
GARUDA_MAX_TX_GRD=1000000

# ── TLS (optional — termination at nginx is recommended instead) ──────────
GARUDA_TLS_CERT=
GARUDA_TLS_KEY=
GARUDA_HTTP_REDIRECT_PORT=

# ── Audit chain ────────────────────────────────────────────────────────────
GARUDA_AUDIT_FILE=/var/log/garudaapi/audit.log

# ── Website / Explorer ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5098

# ── Indexer ────────────────────────────────────────────────────────────────
GARUDA_RPC_URL=http://garudacbdc:REPLACE@127.0.0.1:6301
GARUDA_API_URL=http://127.0.0.1:5098
DB_PATH=./indexer.db
