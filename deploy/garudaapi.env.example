# GarudaAPI production environment file
#
# Copy this to /etc/garudaapi/garudaapi.env (or wherever your systemd unit
# reads from), fill in the real values, and `chmod 600` it so only the
# service user can read it.
#
# Any value left on a dev default will cause `[SECURITY WARN]` lines at
# startup. Scrape those warnings in production and treat them as a P1 —
# they mean a secret is still set to a well-known constant.

# ── Network binding ─────────────────────────────────────────────────────
# Never bind to 0.0.0.0 directly. Put nginx in front of 127.0.0.1.
GARUDA_BIND=127.0.0.1
PORT=5000

# ── Hard mode ───────────────────────────────────────────────────────────
# In strict mode the API never returns internal error details to clients.
# Errors are logged server-side only. Turn this on for any environment
# that accepts untrusted traffic.
GARUDA_STRICT=1

# ── CORS allowlist (comma-separated) ────────────────────────────────────
# Set to the exact public origins that should be able to call this API.
# Leave unset to fall back to "*" (dev only).
GARUDA_ALLOWED_ORIGINS=https://app.garudachain.id,https://dex.garudachain.id

# ── Reverse-proxy trust ─────────────────────────────────────────────────
# Only enable this if nginx is in front and setting X-Forwarded-For. If
# the API is directly reachable by clients, leave this unset — otherwise
# attackers can forge their source IP to bypass rate limits.
GARUDA_TRUST_PROXY=1

# ── Admin key for QRIS/admin endpoints ──────────────────────────────────
# Generate fresh: `openssl rand -hex 32`
# Rotate whenever an operator with access leaves.
GARUDA_ADMIN_KEY=REPLACE_WITH_openssl_rand_hex_32

# ── RPC credentials (MUST match bitcoin.conf in each node's datadir) ────
GARUDA_RPC_USER_CBDC=garudacbdc
GARUDA_RPC_PASS_CBDC=REPLACE_WITH_openssl_rand_hex_24

GARUDA_RPC_USER_PUBLIC=garudapublic
GARUDA_RPC_PASS_PUBLIC=REPLACE_WITH_openssl_rand_hex_24

GARUDA_RPC_USER_CREATOR=garudacreator
GARUDA_RPC_PASS_CREATOR=REPLACE_WITH_openssl_rand_hex_24

# ── Treasury address (fee sink) ─────────────────────────────────────────
# Production: point at a multisig HSM-backed address.
GARUDA_TREASURY_ADDR=grd1qhaclxgx8xhzxjmwg8meuwp7k2ut53t0equ002s

# ── Per-tx cap (GRD) ────────────────────────────────────────────────────
# Absolute maximum for any single amount parameter — sanity cap against
# overflow and operator-error whale-punching.
GARUDA_MAX_TX_GRD=1000000

# ── CBDC mint authority key (hex, 64 chars) ─────────────────────────────
# THIS IS THE CROWN JEWEL. In real production this should come from a
# hardware signer (YubiHSM, AWS KMS, on-prem HSM) — NOT from an env file.
# If you must use an env file for bootstrap, chmod 600 and rotate
# immediately after first mint.
GARUDA_AUTH_PRIVKEY=DO_NOT_STORE_IN_PLAINTEXT_USE_HSM
