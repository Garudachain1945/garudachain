# deploy/seed-node/.env.example
# Copy to .env and fill in before running docker-compose up.

# Public IP of this server (used in -externalip so peers can reach you)
SEED_NODE_IP=REPLACE_WITH_SERVER_PUBLIC_IP

# RPC credentials for garudad (only accessible on 127.0.0.1)
GARUDA_RPC_USER=garudaseed
GARUDA_RPC_PASS=REPLACE_WITH_openssl_rand_hex_24

# DNS hostname this seeder answers (must match NS glue record at registrar)
SEEDER_HOST=seed.garudachain.org
